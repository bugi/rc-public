#!/usr/bin/env bash
# vim: set tabstop=2 softtabstop=2 shiftwidth=2 expandtab autoindent copyindent :

# Tells user what renderer/desktop is in use.
#
# Returns true  if $1 is specified and that renderer is in use.
# Returns false if $1 is specified and that renderer is not in use.
# No text is returned when $1 is specified.
#
# $1 can be specified as "unknown".
#
# If $1 is not specified, outputs the name of the most graphical
# renderer/desktop in use.
#
# When multiple renderers/desktops are in use the text displayed
# is a bit arbitrary but with a definite order.  One particular
# case is that wayland has higher priority than x11 because x11
# is probably available even if wayland is in use.
#
# tty is one possible renderer.
# ssh, screen, and tmux are also considered renderers for this purpose.
#
# Returns false and "unknown" if no known renderer could be detected.

wanted=${1,,} ; shift # ,, makes it lowercase

declare -A gui=()

function test_for_wanted ()
{ # return true if $wanted has a true entry in $gui
  if [[ -n $wanted ]]
  then
    if [[ ${gui[$wanted]} = true ]]
    then
      return 0
    fi
  fi
  return 1
}

[[ -n $DISPLAY ]] && gui[x11]=true

[[ -n $WAYLAND_DISPLAY ]] && gui[wayland]=true

[[ -n $STY ]] && gui[screen]=true
[[ -n $STY ]] && gui[tty]=true

[[ -n $TMUX ]] && gui[tmux]=true
[[ -n $TMUX ]] && gui[tty]=true

[[ -n $SSH_CLIENT ]] && gui[ssh]=true
[[ -n $SSH_TTY ]] && gui[ssh]=true
[[ ${gui[ssh]} = true ]] && gui[tty]=tty

[[ -n $TERM ]] && gui[tty]=tty

# fast path avoids calling launchctl or loginctl if not necessary
test_for_wanted && exit 0

# echo "${!gui[*]}" 1>&2

if [[ $(uname -s) == Darwin ]]
then
  if [[ $(launchctl managername) == Aqua ]]
  then
    gui[quartz]=quartz
  else # == Background
    gui[tty]=tty
  fi
fi

if [[ ${gui[x11]} = false ]] && [[ ${gui[wayland]} == false ]]
then
  if [[ -n $XDG_SESSION_ID ]] && type -f loginctl >/dev/null 2>&1
  then
    answer="$( loginctl show-session "$XDG_SESSION_ID" -p Type | cut -s -f2 -d= )"
    answer=${answer,,}
    gui[$answer]=true
  fi
fi

if [[ -n $XDG_SESSION_ID ]] && type -f loginctl >/dev/null 2>&1
then
  answer="$( loginctl show-session "$XDG_SESSION_ID" -p Desktop | cut -s -f2 -d= )"
  answer=${answer,,}
  gui[$answer]=true
fi


test_for_wanted && exit
if [[ -n $wanted ]]
then
  exit 1
fi


for f in wayland x11 quartz screen tmux ssh tty kde gnome
do
  if [[ ${gui[$f]} = true ]]
  then
    echo "$f"
    exit 0
  fi
done

echo unknown
exit 1
