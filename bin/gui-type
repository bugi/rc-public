#!/usr/bin/env bash
# vim: set tabstop=2 softtabstop=2 shiftwidth=2 expandtab autoindent copyindent :

# Tells user what renderer is in use.
#
# Returns true if $1 is specified and that renderer is available for use.
# Returns false if $1 is specified and that renderer is available for use.
# No text is returned when $1 is specified.
#
# $1 can be specified as "unknown".
#
# Returns true and a renderer name if one is detected, unless $1 is
# specified.  If there is more than one renderer, the more native one is
# returned.  For example, quartz is returned on macos even if an Xorg
# server is running.  Wayland is returned when both Wayland and Xorg are
# running.
#
# "tty" can be returned, but it is not the fallback.
#
# Returns false and "unknown" if no known renderer could be detected.

# If called as program name x11-or-wayland, always returns false
# if neither x11 nor wayland is available for use.

wanted=${1,,} ; shift # ,, makes it lowercase
bname="$(basename "$0")"

# true if was called as x11-or-wayland
is_x11_or_wayland=false
if [[ $bname = x11-or-wayland ]]
then
  is_x11_or_wayland=true
fi

special_x11_or_wayland ()
{ # If there is an arg of pass-on-unknown, we don't exit unless we know whether we're x11 or wayland.
  # otherwise:
  # Always exits if the special case of x11-or-wayland is satisfied.
  # If it returns, it returns true, but true doesn't mean anything.
  if ! $is_x11_or_wayland
  then
    true
    return
  fi
  # check the x11-or-wayland case early to avoid OS calls in a common case
  if [[ -n $wanted ]]
  then
    if $isWayland && [[ $wanted = wayland ]]
    then
      exit 0
    elif $isX11 && [[ $wanted = x11 ]]
    then
      exit 0
    fi
  elif [[ -z $wanted ]]
  then
    if $isWayland
    then
      echo wayland
      exit 0
    elif $isX11
    then
      echo x11
      exit 0
    fi
  fi
  # none of the known conditions is satisfied, so we default to exit 1
  if [[ $1 == pass-on-unknown ]]
  then
    false
    return
  fi
  exit 1
}

function test_for_wanted ()
{
  if [[ -n $wanted ]]
  then
    case "$wanted" in
      (wayland) $isWayland ; exit ;;
      (x11) $isX11 ; exit ;;
      (quartz|macos) $isQuartz ; exit ;;
      (screen) $isScreen ; exit ;;
      (tmux) $isTMUX ; exit ;;
      (ssh) $isSSH ; exit ;;
      (tty) $isTTY ; exit ;;
    esac
  fi
}
function test_for_wanted2 ()
{ # tests for cases that we can't determine before exhausting all other $wanted possibilities
  if [[ -n $wanted ]]
  then
    case "$wanted" in
      (unknown|other) true ; exit ;;
      (*) exit 1 ;;
    esac
  fi
}



isWayland=false
if [[ -n $WAYLAND_DISPLAY ]]
then
  isWayland=true
  [[ $wanted = wayland ]] && exit 0
fi

isX11=false
if [[ -n $DISPLAY ]]
then
  isX11=true
  [[ $wanted = x11 ]] && exit 0
fi

isScreen=false
if [[ -n $STY ]]
then
  isScreen=true
  isTTY=true
fi

isTMUX=false
if [[ -n $TMUX ]]
then
  isTMUX=true
  isTTY=true
fi

isSSH=false
if [[ -n $SSH_CLIENT ]] || [[ -n $SSH_TTY ]]
then
  isSSH=true
  isTTY=true
fi

isTTY=false
if [[ -n $TERM ]]
then
  isTTY=true
fi

special_x11_or_wayland pass-on-unknown  # doesn't exit even in the special case
R=$?

if [[ $R -eq 0 ]]
then
  # early test to short circuit calling launchctl or loginctl
  test_for_wanted
fi

isQuartz=false
if [[ $(uname -s) == Darwin ]]
then
  if [[ $(launchctl managername) == Aqua ]]
  then
    isQuartz=true
  else # == Background
    isTTY=true
  fi
fi

if ! $isX11 && ! $isWayland
then
  if [[ -n $XDG_SESSION_ID ]] && type -f loginctl >/dev/null 2>&1
  then
    answer="$( loginctl show-session "$XDG_SESSION_ID" -p Type | cut -s -f2 -d= )"
    case "$answer" in
      (wayland) isWayland=true ;;
      (x11) isX11=true ;;
      (tty)
        # means no display manager, like if one were to tunnel x11 via ssh
        # It is possible to wind up with isX11 and isTTY both true.
        isTTY=true
        ;;
    esac
  fi
fi

# echo "umm isQuartz($isQuartz) isWayland($isWayland) isX11($isX11) answer($answer) wanted($wanted) R_on_match($R_on_match)" 1>&2

special_x11_or_wayland   # exits on the special case

test_for_wanted
test_for_wanted2

if $isWayland
then
  echo wayland
  exit 0
elif $isX11
then
  echo x11
  exit 0
elif $isQuartz
then
  echo quartz
  exit 0
elif $isScreen
then
  echo screen
  exit 0
elif $isTMUX
then
  echo tmux
  exit 0
elif $isSSH
then
  echo ssh
  exit 0
elif $isTTY
then
  echo tty
  exit 0
else
  echo unknown
  exit 0
fi
