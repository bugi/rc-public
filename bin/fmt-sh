#!/usr/bin/env bash
# vim: set tabstop=2 softtabstop=2 shiftwidth=2 expandtab autoindent copyindent :

shfmt_exists=false
beautysh_exists=false
if type shfmt >/dev/null 2>&1
then
  shfmt_exists=true
fi
if type beautysh >/dev/null 2>&1
then
  :
  beautysh_exists=true
fi

if ! $shfmt_exists && ! $beautysh_exists
then
  echo "I just passed your input through unchanged because you have neither both shfmt nor beautysh installed." 1>&2
  exec cat
fi

passthrough=true
diff=false
replace=false
shfmt_use=true
beautysh_use=true
lint=false
$shfmt_exists || shfmt_use=false
$beautysh_exists || beautysh_use=false

if [[ ! -t 0 ]] && read -t 0
then
  # assume user wants to just format stdin to stdout
  passthrough=true
  diff=false
  replace=false
else
  diff=true
  replace=false
  passthrough=false
fi

# @formatter:off
while [[ $# -gt 0 ]]
do

  case "$1" in
  (--pipe)
    shift
    passthrough=true
    diff=false
    replace=false
    ;;
  (--diff)
    shift
    diff=true
    replace=false
    ;;
  (--replace)
    shift
    replace=true
    diff=false
    ;;
  (--shfmt|--shfmt=true)
    shift
    shfmt_use=true
    ;;
  (--shfmt=false)
    shift
    shfmt_use=false
    ;;
  (--beautysh|--beautysh=true)
    shift
    beautysh_use=true
    ;;
  (--beautysh=false)
    shift
    beautysh_use=false
    ;;
  (--lint)
    shift
    lint=true
    beautysh_cmd=( beautysh )
    beautysh_cmd+=( --indent-size 2 )
    exec "${beautysh_cmd[@]}" --check "$@"
    ;;
  (--*) echo "unknown argument «$1»" 2>&1 ; exit ;;
  (-) fn="$1" ; shift ; passthrough=true ;;
  (-*) echo "unknown argument «$1»" 2>&1 ; exit ;;
  (*) fn="$1" ; shift ;;
  esac

done
# @formatter:on

function _fmt()
{
  local shfmt_cmd=( shfmt )
  shfmt_cmd+=( --indent 2 )
  shfmt_cmd+=( --func-next-line )
  shfmt_cmd+=( --binary-next-line --space-redirects --keep-padding )
  shfmt_cmd+=( --case-indent )
  # shfmt_cmd+=( --language-dialect bash )
  local beautysh_cmd=( beautysh )
  beautysh_cmd+=( --indent-size 2 )
  if $shfmt_use && $beautysh_use
  then
    "${shfmt_cmd[@]}" - \
    | sed 's/; do$/\ndo/;s/; then$/\nthen/' \
    | "${beautysh_cmd[@]}" -
  elif $shfmt_use
  then
    "${shfmt_cmd[@]}" -
  elif $beautysh_use
  then
    "${beautysh_cmd[@]}" -
  else
    cat
  fi
}

function _diff()
{
  local f0="$1"
  local f1="$2"
  if [[ -t 1 ]]
  then
    diff -uNd --color=always "$f0" "$f1" | less -FRXi
  else
    diff -uNd "$f0" "$f1"
  fi
}

tmpfile=
tmpfile2=
function on_exit()
{
  if [[ -n $tmpfile ]] && [[ -f $tmpfile ]]
  then
    rm -f "$tmpfile"
    tmpfile=
  fi
  if [[ -n $tmpfile2 ]] && [[ -f $tmpfile2 ]]
  then
    rm -f "$tmpfile2"
    tmpfile2=
  fi
}
trap on_exit EXIT

if $passthrough
then
  if $replace
  then
    echo "Replace mode makes no sense with input from stdin." 1>&2
    exit 1
  fi
  if [[ $fn = - ]]
  then
    if [[ ! -t 0 ]] && read -t 0
    then
      # fall through to regular stdin parsing
      fn=
    else
      # treat this case as an empty stdin
      exit 0
    fi
  fi
  if [[ ! -t 0 ]] && read -t 0
  then
    if $diff
    then
      tmpfile="$(mktemp)"
      tmpfile2="$(mktemp)"
      cat >| "$tmpfile2"
      cat "$tmpfile2" | _fmt >| "$tmpfile"
      _diff "$tmpfile2" "$tmpfile"
      exit
    else
      _fmt
      exit
    fi
  fi
  if [[ -n $fn ]] && [[ -r $fn ]]
  then
    # This just mean that we will not replace the file.
    # ignores args beyond $1
    if $diff
    then
      tmpfile="$(mktemp)"
      # tmpfile2="$(mktemp)"
      # cat >| "$tmpfile2"
      cat "$fn" | _fmt >| "$tmpfile"
      _diff "$fn" "$tmpfile"
      exit
    else
      cat "$fn" | _fmt
      exit
    fi
  fi
  echo "You want me to format what?  Gimme a filename or something on stdin." 2>&1
  exit 1
fi

tmpfile="$(mktemp)"
cat "$fn" | _fmt >| "$tmpfile"

if $diff
then
  _diff "$fn" "$tmpfile"
fi

if $replace
then
  mv "$tmpfile" "$fn"
fi
